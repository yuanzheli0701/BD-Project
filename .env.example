# ------------------------------------------------------------------------
# City Mood × Weather Correlation Analysis - Environment Configuration
# ------------------------------------------------------------------------
# Copy this file to .env and fill in your API keys before running the project.
#
# Spotify API: https://developer.spotify.com/dashboard
#   - Create an app, get Client ID + Client Secret
#
# OpenWeatherMap: https://openweathermap.org/api
#   - Sign up for a free account, get API key (One Call API 3.0 recommended)
#
# ------------------------------------------------------------------------

SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

OPENWEATHER_API_KEY=your_openweathermap_api_key_here

DATA_LAKE_ROOT=data

SPARK_APP_NAME=CityMoodWeather
SPARK_MASTER=local[*]

ES_HOST=http://localhost:9200
ES_INDEX=city_depression_index

CITIES=Paris,FR|London,GB|New York,US|Tokyo,JP|Berlin,DE|Sydney,AU|Mumbai,IN|Sao Paulo,BR|Moscow,RU|Seoul,KR

SPOTIFY_REGIONS=global,fr,gb,us,jp,de,au,in,br,ru,kr
